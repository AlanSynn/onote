{
  "name": "onote-docs",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "description": "Documentation + landing site for onote (Astro → GitHub Pages at alansynn.com/onote/)",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && npm run build:downloads && npm run build:pdf && npm run build:search",
    "build:fast": "astro build && npm run build:downloads && npm run build:search",
    "build:downloads": "node scripts/build-downloads.mjs",
    "build:pdf": "bash scripts/build-pdf.sh",
    "build:search": "pagefind --site dist",
    "preview": "astro preview --base /onote",
    "astro": "astro"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "archiver": "^7.0.1",
    "astro": "^5.13.0",
    "pagefind": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.25.12": true
  }
}
