---
const base = import.meta.env.BASE_URL;
const repo = 'https://github.com/AlanSynn/onote';
const year = 2026;
---

<footer class="footer" data-pagefind-ignore>
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__mark" aria-hidden="true">❯</span>
      <span>onote</span>
      <span class="footer__dim">— the terminal scratchpad for your obsidian vault.</span>
    </div>
    <nav class="footer__links" aria-label="Footer">
      <a href={`${base}manual`}>Manual</a>
      <a href={`${base}manual/install`}>Install</a>
      <a href={repo} rel="noopener">GitHub</a>
      <a href={`${base}manual/guarantees`}>Design guarantees</a>
    </nav>
    <p class="footer__meta">
      v0.4.1 · MIT · © {year} Alan Synn
    </p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    border-top: 1px solid var(--border);
    background: var(--bg-sunken);
  }
  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-block: 2rem;
  }
  .footer__brand {
    font-family: 'JetBrains Mono Variable', monospace;
    font-weight: 700;
    font-size: 0.95rem;
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .footer__mark {
    color: var(--accent-text);
  }
  .footer__dim {
    color: var(--fg-muted);
    font-weight: 500;
    font-size: 0.85rem;
  }
  .footer__links {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 1.1rem;
  }
  .footer__links a {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--fg-muted);
    text-decoration: none;
  }
  .footer__links a:hover {
    color: var(--accent-text);
    text-decoration: none;
  }
  .footer__meta {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.76rem;
    color: var(--fg-muted);
    margin: 0;
  }
</style>
