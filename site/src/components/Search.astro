---
// Pagefind static search. The PagefindUI bundle is generated by
// `pagefind --site dist` into dist/pagefind/ and served at /onote/pagefind/.
// CRITICAL: `baseUrl: '/onote/'` is hard-set — Pagefind's auto-detect does NOT
// infer the project subpath, and without it every result link 404s. In dev the
// bundle doesn't exist yet, so the dynamic import silently no-ops.
---

<div class="search" id="onote-search" aria-label="Search the manual"></div>

<script>
  const el = document.getElementById('onote-search');
  if (el) {
    const base = '/onote/';
    const tryLoad = async () => {
      try {
        // @vite-ignore + string concat stops the bundler resolving the path at
        // build time (the file only exists after `pagefind --site dist`).
        const mod = await import(/* @vite-ignore */ base + 'pagefind/pagefind-ui.js');
        new mod.PagefindUI({
          element: '#onote-search',
          baseUrl: base,
          showImages: false,
          translations: { placeholder: 'Search the manual…' },
        });
      } catch {
        el.textContent = 'Search is available in the published site.';
        el.classList.add('search--idle');
      }
    };
    tryLoad();
  }
</script>

<style is:global>
  .search {
    margin-bottom: 1.25rem;
  }
  .search--idle {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.78rem;
    color: var(--fg-muted);
  }
  /* Pagefind UI theming — recolor to Catppuccin. */
  .pf-ui-input {
    background: var(--bg-inset) !important;
    border: 1px solid var(--border) !important;
    color: var(--fg) !important;
    border-radius: 0.45rem !important;
    font-family: 'JetBrains Mono Variable', monospace !important;
    font-size: 0.85rem !important;
  }
  .pf-ui-input:focus {
    border-color: var(--accent) !important;
  }
  .pf-result {
    border-color: var(--border) !important;
  }
  .pf-result-title {
    color: var(--link) !important;
  }
  .pf-result-excerpt {
    color: var(--fg-muted) !important;
  }
</style>
