---
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import ManualDownload from '../components/ManualDownload.astro';
import PageDownload from '../components/PageDownload.astro';
import { prevNext } from '../lib/nav';

interface Props {
  id: string;
  title: string;
  description: string;
}
const { id, title, description } = Astro.props;
const { prev, next } = await prevNext(id);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-theme="latte">
  <head>
    <BaseHead title={`${title} — onote manual`} description={description} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <Nav />
    <div class="manual container">
      <Sidebar current={id} />
      <main id="content" class="manual__main">
        <div class="manual__toolbar">
          <p class="manual__crumb">
            <a href={`${base}manual`}>Manual</a> <span aria-hidden="true">/</span> {title}
          </p>
          <ManualDownload />
        </div>
        <article class="prose manual__article" data-pagefind-body>
          <slot />
        </article>
        <footer class="manual__foot">
          <PageDownload id={id} />
          <nav class="pager" aria-label="Page">
            {prev ? (
              <a class="pager__link pager__prev" rel="prev" href={`${base}manual/${prev.id}`}>
                <span class="pager__dir">← Previous</span>
                <span class="pager__title">{prev.title}</span>
              </a>
            ) : <span class="pager__placeholder" />}
            {next ? (
              <a class="pager__link pager__next" rel="next" href={`${base}manual/${next.id}`}>
                <span class="pager__dir">Next →</span>
                <span class="pager__title">{next.title}</span>
              </a>
            ) : <span class="pager__placeholder" />}
          </nav>
        </footer>
      </main>
    </div>
    <Footer />

    <style is:global>
      .skip-link {
        position: absolute;
        left: 0.75rem;
        top: -3rem;
        z-index: 50;
        padding: 0.5rem 0.8rem;
        background: var(--accent);
        color: var(--accent-fg);
        border-radius: 0 0 0.4rem 0.4rem;
        font-family: 'JetBrains Mono Variable', monospace;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        transition: top 0.15s ease;
      }
      .skip-link:focus {
        top: 0;
      }

      .manual {
        display: grid;
        grid-template-columns: 16rem minmax(0, 1fr);
        gap: 2.5rem;
        align-items: start;
        padding-block: 2rem 1rem;
      }
      .manual__main {
        min-width: 0;
      }
      .manual__toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        padding-bottom: 1rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
      }
      .manual__crumb {
        margin: 0;
        font-family: 'JetBrains Mono Variable', monospace;
        font-size: 0.8rem;
        color: var(--fg-muted);
      }
      .manual__crumb a {
        color: var(--fg-muted);
      }
      .manual__crumb a:hover {
        color: var(--accent-text);
      }
      .manual__article :first-child {
        margin-top: 0;
      }
      .manual__foot {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
      }
      .pager {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 1.25rem;
      }
      .pager__link {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        padding: 0.7rem 0.9rem;
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        text-decoration: none;
        max-width: 48%;
      }
      .pager__link:hover {
        text-decoration: none;
        border-color: var(--accent-text);
      }
      .pager__next {
        text-align: right;
        margin-left: auto;
      }
      .pager__dir {
        font-family: 'JetBrains Mono Variable', monospace;
        font-size: 0.72rem;
        color: var(--fg-muted);
      }
      .pager__title {
        font-family: 'JetBrains Mono Variable', monospace;
        font-weight: 700;
        font-size: 0.92rem;
        color: var(--fg);
      }
      .pager__placeholder {
        max-width: 48%;
      }

      @media (max-width: 1023px) {
        .manual {
          grid-template-columns: minmax(0, 1fr);
          gap: 1rem;
        }
      }
    </style>
  </body>
</html>
