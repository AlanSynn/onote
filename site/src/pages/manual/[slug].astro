---
import { getCollection, render } from 'astro:content';
import ManualLayout from '../../layouts/ManualLayout.astro';

// One route per manual page. `id` is the glob-loader key (= filename without
// extension; flat dir → single segment), so `[slug]` (not a rest param) is the
// right route. getStaticPaths is called at build time only.
export async function getStaticPaths() {
  const pages = await getCollection('manual');
  return pages.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ManualLayout
  id={entry.id}
  title={entry.data.title}
  description={entry.data.description}
>
  <Content />
</ManualLayout>
